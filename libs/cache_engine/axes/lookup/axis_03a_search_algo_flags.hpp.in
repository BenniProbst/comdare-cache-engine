#cmakedefine01 COMDARE_AXIS_03A_USE_K_ARY_K2
#cmakedefine01 COMDARE_AXIS_03A_USE_K_ARY_K4
#cmakedefine01 COMDARE_AXIS_03A_USE_K_ARY_K8
#cmakedefine01 COMDARE_AXIS_03A_USE_K_ARY_K16

// V41.F.6.1 R7.2 (2026-05-29) — S11 InterpolationSearchAlgo: interpolation search (Perl/Itai/Avni
// CACM 1978), verteilungsbewusste Such-METHODE (O(log log N) avg bei Gleichverteilung), kein SIMD.
#cmakedefine01 COMDARE_AXIS_03A_USE_INTERPOLATION

// V41.F.6.1 R7.2 (2026-05-29) — S12 EytzingerSearchAlgo: cache-conscious BFS-Layout + branch-free
// Suche (Khuong/Morin JEA 2017), Speicher-Layout-Such-METHODE.
#cmakedefine01 COMDARE_AXIS_03A_USE_EYTZINGER

// V41.F.6.1 R7.2 (2026-05-29) — S13 SkipListSearchAlgo: probabilistische geordnete STRUKTUR
// (Pugh CACM 1990), erweitert die Achse von Such-Methoden in die Struktur-Dimension.
#cmakedefine01 COMDARE_AXIS_03A_USE_SKIP_LIST

// V41.F.6.1 R7.2 (2026-05-29) — S14 HashSearchAlgo: ungeordnete open-addressing Hashtabelle
// (Knuth TAOCP 3 §6.4), das fundamentale Hash-Such-Paradigma (kein Range-Scan).
#cmakedefine01 COMDARE_AXIS_03A_USE_HASH_SEARCH

// V41.F.6.1 R7.2 (2026-05-29) — S15 LinearScanSearchAlgo: unsortierter linearer Scan
// (ART-Node4-Baseline, Leis ICDE 2013), der einfachste Vergleichs-Nullpunkt (kein Range-Scan).
#cmakedefine01 COMDARE_AXIS_03A_USE_LINEAR_SCAN

// V41.F.6.1 R7.2 (2026-05-29) — S16 BinarySearchTreeSearchAlgo: unbalancierter BST (Hibbard-Deletion,
// Knuth TAOCP 3 §6.2.2), deterministische Vergleichs-Baum-Baseline (vs SkipList probabilistisch).
#cmakedefine01 COMDARE_AXIS_03A_USE_BST

// V41.F.6.1 R7.2 (2026-05-29) — S17 BTreeSearchAlgo: balancierter block-orientierter Mehrwege-B-Baum
// (Bayer/McCreight Acta Inf. 1972 / CLRS Kap. 18, t=4), das DB-Index-Arbeitspferd; Node alignas(64).
#cmakedefine01 COMDARE_AXIS_03A_USE_BTREE

