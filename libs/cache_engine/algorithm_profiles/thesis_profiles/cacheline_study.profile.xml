<!-- comdare_thesis_profile — Diplomarbeit Cache-Line-Konfigurator (KF-2, 2026-06-02)
     Schema-Doku: SCHEMA.md (gleicher Ordner). Baut additiv auf:
       - permutation_axes.xml (11 Achsen-Wertebereiche, ../permutation_axes.xml) — HISTORISCHER Alias-Stand
       - sota/*.profile.xml    (Paper-Originale = statische Achsen-Tupel)
     Design: docs/sessions/20260602-cacheline-konfigurator-design-und-hw-recherche.md
     KEINE bestehende Datei wird geaendert (Rueckwaerts-Kompatibilitaet).
     KANONISIERT (GO-4/GO-5-Nebenbefund, 2026-07-12): die <axis ref>-Namen/-Werte sind auf die kanonischen
     Registry-Namen gezogen (kCompositionAxisNames/EnabledStrategies, wie m3v2/m3_golden_coverage) — die
     permutation_axes.xml-Aliasse der KF-2-Aera (layout/node/traversal/page + GROSS-Werte wie X86_SSE42/
     SYSTEM_MALLOC) kennt die AxisRegistry nicht mehr; `messung_driver -validate` prueft gegen die Registry.
     Uebersetzung: layout->memory_layout, traversal->cache_traversal, node->node_type, page->page_type,
     isa{X86_SSE42/AVX2/AVX512} -> isa{isa_amd64} x simd_extension{simd_ext_sse2/avx2/avx512} (die Registry
     fuehrt kein SSE4.2; simd_ext_sse2 = niedrigste x86-SIMD-Stufe), allocator{SYSTEM_MALLOC/JEMALLOC/MIMALLOC}
     -> volle USE-Enabled-Liste (enable-agnostisch wie m3_smoke_coverage; jemalloc/mimalloc sind HAVE-gated
     und kommen automatisch dazu, sobald der Vendor im Build vorhanden ist).
     A1-FEHLPLATZIERUNGS-FIX (2026-07-20, S3-Resolver-Aktivierung): die 2026-07-12-"Uebersetzung" liess isa/
     simd_extension/page_type FAELSCHLICH in der permute_axes-Organ-Position stehen - das sind aber System-/
     Build-Achsen, KEINE der 17 Organ-Kompositions-Achsen. Der jetzt aktive S3-Resolver klassifizierte sie
     (V-UNREG-AXIS). Kanonisiert: isa->target_isa + simd_extension->extension_hardware/simd in den <system_axes>-
     Block (unten); page_type (Baum-Knoten-PageKind = axis_01_page_type Build-Variante) raus als ZUKUNFT
     (§52-B10; s. FP-Kommentare). Damit 0 Rejects im -dump-plan. -->
<comdare_thesis_profile id="cacheline_study" schema_version="1">

  <!-- (a) BASIS-TIERE = Paper-Originale in Standardkonfig (statische Achsen-Tupel).
       Jedes Tier liefert die Werte der NICHT-permutierten (statischen) Achsen.
       Als EINE gekreuzte Dimension behandelt (inverse Auswertungslogik §7-B): ein Grossexperiment. -->
  <base_tiers>
    <tier id="art"      profile_ref="../sota/art.profile.xml"       paper_ref="P01"/>
    <tier id="hot"      profile_ref="../sota/hot.profile.xml"       paper_ref="P02"/>
    <tier id="masstree" profile_ref="../sota/masstree.profile.xml"  paper_ref="P03"/>
    <tier id="coco"     profile_ref="../sota/coco_trie.profile.xml" paper_ref="P04"/>
    <tier id="start"    profile_ref="../sota/start.profile.xml"     paper_ref="P05"/>
    <tier id="b2tree"   profile_ref="../sota/b2tree.profile.xml"    paper_ref="P06"/>
    <tier id="wormhole" profile_ref="../sota/wormhole.profile.xml"  paper_ref="P07"/>
    <tier id="surf"     profile_ref="../sota/surf.profile.xml"      paper_ref="P10"/>
  </base_tiers>

  <!-- (b) PERMUTIERTE (dynamische) ACHSEN = cache-line-relevant, COMPILE-TIME.
       Kein <value> => volle Liste aus der Achsen-Registry (EnabledStrategies); mit <value> => Teilmenge.
       Achsen-/Werte-Namen = kanonische Registry-Namen (Kopf-Kommentar: KANONISIERT 2026-07-12). -->
  <permute_axes>
    <axis ref="memory_layout"/>
    <!-- FP-1/FP-2 (A1 Fehlplatzierungs-Fix, 2026-07-20): isa + simd_extension VERLIESSEN die Organ-Position.
         Sie sind SYSTEM-Achsen (target_isa bzw. extension_hardware/simd), NICHT organ-kompositional (nicht unter
         den 17 kCompositionAxisNames) und wurden in Organ-Position vom Resolver klassifiziert verworfen. Kanonisch
         im <system_axes>-Block unten (geteilte parse_system_axes-Naht, S2/A2). Der Alt-SIMD-Stufen-Spread
         {SSE42/AVX2/AVX512} lebt jetzt dort (SSE4.2 hat kein Registry-Aequivalent -> niedrigste reale = no_extension). -->
    <axis ref="cache_traversal"/>
    <axis ref="node_type"/>
    <!-- FP-3 (A1, 2026-07-20; Ledger §52-B10): der Alt-Ref page_type meinte die BAUM-KNOTEN-PageKind
         (permutation_axes.xml axis id="page" = "Page-Layout der Knoten": DENSEBYTE_ART256/HOT_MULTIBYTE/... =
         axis_01_page_type), NICHT die Hardware-Huge-Page (§52-B10-Namensfalle: axis_01_page_type ist NICHT
         alloc_hw.page bzw. general_hardware). axis_01_page_type ist eine BUILD-VARIANTE
         (axis_observer_classification.hpp: DefinitionOnly; NICHT unter den 17 Organ-Achsen; profile_to_tree.hpp
         verwarf sie in Organ-Position ohnehin still) -> KEINE gueltige Organ-Registry-Achse. Sie hat (anders als
         isa/simd_extension) heute KEINEN <system_axes>-Parser-Kanal ("KEINE neue Achse") -> raus aus der
         Organ-Position, dokumentiert als ZUKUNFT-Build-Variante (analog target_isa/compiler-FAMILIE in
         all_axes_golden). NICHT nach alloc_hw kanonisiert (das waere die §52-B10-Namensfalle). -->
    <axis ref="prefetch"/>
    <!-- Alt-Intent allocator{SYSTEM_MALLOC/JEMALLOC/MIMALLOC}: repraesentative Familien-Teilmenge.
         Kanonisch enable-agnostisch OHNE <value> = volle USE-Enabled-Liste des Builds (std_malloc/pmr/pool
         immer; jemalloc/mimalloc HAVE-gated automatisch dazu — kein build-varianter Validate-Bruch). -->
    <axis ref="allocator"/>

    <!-- NEUE per-Organ Cache-Line-Unterachse (KF-3, Kernthema §4.3): JEDES benannte Organ
         traegt eine EIGENE, unabhaengige Cache-Line-Einstellung -> bis 60^4 (beabsichtigt).
         C1 (GO4/#8 F-C, 2026-07-12): line_size 32 ADDITIV ergaenzt (KF-5 thesis-treu {32,64,128};
         32 = embedded, D_building_block_matrix.tex:251). ANS ENDE angehaengt, damit die Reihenfolge
         der bestehenden Werte (und damit deren Ebenen-Ordnung im Experiment-Baum) stabil bleibt.
         per_organ = dokumentarische Cache-Line-Traeger-Namen (node_type/cache_traversal/allocator = Organe;
         page_type = die Baum-Knoten-PageKind-Build-Variante, s. FP-3 oben) - reine Metadaten, KEIN Resolver-
         Check (organ_position_refs iteriert NUR <axis ref>, cacheline ist Sonderzweig), KEINE binary_id. -->
    <axis ref="cacheline" per_organ="page_type node_type cache_traversal allocator">
      <line_size>64</line_size>
      <line_size>128</line_size>
      <line_size>256</line_size>
      <line_size>32</line_size>
      <alignment>none</alignment>
      <alignment>cacheline_aligned</alignment>
      <alignment>padded</alignment>
      <sw_prefetch_hint>none</sw_prefetch_hint>
      <sw_prefetch_hint>T0</sw_prefetch_hint>
      <sw_prefetch_hint>T1</sw_prefetch_hint>
      <sw_prefetch_hint>T2</sw_prefetch_hint>
      <sw_prefetch_hint>NTA</sw_prefetch_hint>
    </axis>
  </permute_axes>

  <!-- (c) COMPILE-TIME Mess-Dimensionen (je Binary gebacken, kein Runtime-Switch). -->
  <compile_dims>
    <workloads>ycsb_a ycsb_b ycsb_c ycsb_d ycsb_e ycsb_f</workloads>
    <telemetry mode="on" silent="true"/>   <!-- §8: AN + silent-mode (Snapshot-Diff, unverfaelscht) -->
  </compile_dims>

  <!-- (d) DYNAMISCHE OS-Laufzeit-Dimensionen — der CacheEngineBuilder durchlaeuft sie am Pruef-Dock
       zur Laufzeit in Env-/Ressourcengrenzen (Faustregel §7; KF-7). -->
  <runtime_dynamic>
    <!-- T8-Phantom-Fix nachgezogen (vorbestehender Befund, 2026-07-12): runtime_thread_count() hat null
         Consumer — Werte >1 waeren mehrfach etikettierte identische Messungen (Muster ff2/fb/m3_smoke;
         test_kf1 pinnt 1). Alt-Intent "1 2 4" (KF-4/KF-7) kehrt zurueck, sobald T8 echte Consumer hat. -->
    <thread_count>1</thread_count>                              <!-- via Algorithm_Resource_Control (KF-4) -->
    <hw_prefetcher>all_on adjacent_off all_off</hw_prefetcher>  <!-- via MSR 0x1A4 (Launcher KF-12) -->
  </runtime_dynamic>

  <!-- (e) FIXE reproduzierbare Bedingungen (Launcher, konstant fuer ALLE Laeufe). -->
  <fixed_conditions turbo="off" smt="off" aslr="off" numa="local" governor="performance"/>

  <!-- (f) WIEDERHOLUNGEN — alle Laeufe vollstaendig + separat, NIE interpoliert (§9, KF-10). -->
  <repetitions count="3" interpolate="false" overlay_in_chart="true"/>

  <!-- (g) 3 PERMUTATIONSMODI, je auf Achsen-Teilmenge beschraenkt (pruefling_merge.hpp; KF-9). -->
  <modes>
    <mode name="ce_only"           merge="Stufe1_CeOnly"
          active_axes="memory_layout isa simd_extension cache_traversal node_type page_type prefetch allocator cacheline"/>
    <mode name="pruefling_replace" merge="Stufe2_PrueflingReplace"
          pruefling="prtart" replaces_axes="page_type node_type cache_traversal value_handle allocator prefetch memory_layout"
          active_axes="isa simd_extension cacheline"/>
    <mode name="full_join"         merge="Stufe3_FullJoin"
          active_axes="memory_layout isa simd_extension cache_traversal node_type page_type prefetch allocator cacheline"/>
  </modes>

  <!-- (h) STATISCHE Achsen kommen aus dem jeweiligen base_tier (Paper-Tupel); Cross-Constraints. -->
  <static_axes from="base_tier"/>   <!-- value_handle, concurrency-Mechanismus, reclamation, telemetry-Basis -->
  <constraints>
    <require axis="isa" host_supported="true"/>
    <!-- thread_count>1 nur sinnvoll, wenn das Tier eine nebenlaeufige concurrency-Mechanik traegt;
         der CacheEngineBuilder begrenzt den Durchlauf entsprechend (KF-7). -->
  </constraints>

  <key_value_signature>
    <key_types>std::uint64_t</key_types>
    <value_types>std::string</value_types>
  </key_value_signature>

  <!-- (sys) SYSTEM-ACHSEN (A1 Fehlplatzierungs-Fix, 2026-07-20; geteilte parse_system_axes-Naht, S2/A2 P-SYSREG):
       die frueher fehlplatzierten Organ-Position-Refs isa + simd_extension sind hierher kanonisiert.
       extension_hardware/simd = die SIMD-System-Achse (Alt-Ref simd_extension); der Alt-Stufen-Spread
       {SSE42/AVX2/AVX512} bildet auf die realen SimdSubAxis-Stufen ab (simd_ext_sse2 -> no_extension = niedrigste
       reale x86-Stufe, die Registry fuehrt kein SSE4.2; dazu avx2 + avx512). target_isa = die ISA-System-Achse
       (Alt-Ref isa, Wert isa_amd64 -> x86_64-Baustein). system_config -> binary_id-NEUTRAL (multipliziert NUR die
       Bau-Matrix/Sidecar, NIE die 17-Organ-Kartesik). page_type (Baum-Knoten-PageKind = axis_01_page_type
       Build-Variante) hat heute KEINEN Parser-Kanal und bleibt ZUKUNFT (s. FP-3 oben) - hier bewusst NICHT
       aufgefuehrt. -->
  <system_axes>
    <extension_hardware>
      <simd>
        <option value="no_extension"/>
        <option value="avx2"/>
        <option value="avx512"/>
      </simd>
    </extension_hardware>
    <target_isa>
      <option value="x86_64"/>
    </target_isa>
  </system_axes>

  <!-- (mess) MESS-UNTER-ACHSEN [A9.2 = S4-Delta B9 Profil-Fuellung WAS/WIE, 2026-07-20; PASSIV, Planer-delegiert]:
       binary_id-NEUTRAL. Parse + validate gegen die constexpr-Mess-Registries, aber der Plan-Director konsumiert
       measurement_tooling NICHT (measurement_combos_of(categories) => 1 Voll-Konfig [all]) -> -dump-plan byte-
       identisch; der N>1-Fan-out gehoert S5/P-MESSTOOL. Ids-Single-Source = die Mess-Registries. run_methodology:
       measure (Standard-Messmodus, 1-Thread/deterministisch); measurement_framework: ycsb (honest-1);
       writeback_methods: csv (die maschinen-lesbare Roh-Wahrheit); measurement_tooling: wallclock (konservativ -
       N>1 dormant bis S6). -->
  <run_methodology>
    <method value="measure"/>
  </run_methodology>
  <measurement_framework name="ycsb"/>
  <writeback_methods>
    <method value="csv"/>
  </writeback_methods>
  <measurement_tooling>
    <combo tools="wallclock"/>
  </measurement_tooling>
</comdare_thesis_profile>
